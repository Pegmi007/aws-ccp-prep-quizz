{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/service-worker.js",
      "headers": {
        "cache-control": "public, max-age=0, must-revalidate"
      },
      "destination": "/service-worker.js"
    },
    {
      "source": "/manifest.json",
      "headers": {
        "cache-control": "public, max-age=0, must-revalidate"
      },
      "destination": "/manifest.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
